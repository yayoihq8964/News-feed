# ============================================
# MacroLens - 宏观新闻情绪分析平台
# ============================================

# ---------- 新闻源 API Keys ----------
# Finnhub (https://finnhub.io - 免费注册)
FINNHUB_API_KEY=

# NewsAPI (https://newsapi.org - 免费注册, 100次/天)
NEWSAPI_API_KEY=

# GNews (https://gnews.io - 免费注册, 100次/天)
GNEWS_API_KEY=

# Massive (https://massive.com - 免费注册, 实时性好)
MASSIVE_API_KEY=

# Google News RSS + Seeking Alpha RSS — 免费无需 Key，自动启用

# ---------- 默认 LLM 配置 ----------
# 可选: openai / anthropic / grok / ollama
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o
DEFAULT_LLM_API_KEY=

# ---------- LLM Provider Keys ----------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROK_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ---------- 应用设置 ----------
# 新闻拉取间隔(秒)
NEWS_POLL_INTERVAL=120
# 每批分析数量
ANALYSIS_BATCH_SIZE=5
# 社交情绪估算间隔(秒) - LLM估算，非实时社交数据
X_SENTIMENT_INTERVAL=1800

# ---------- CORS ----------
# 生产环境请设置为前端域名，逗号分隔
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
