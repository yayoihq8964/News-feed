# ============================================
# MacroLens - 宏观新闻情绪分析平台
# ============================================

# ---------- 新闻源 API Keys ----------
# Finnhub (https://finnhub.io - 免费注册)
FINNHUB_API_KEY=

# NewsAPI (https://newsapi.org - 免费注册, 100次/天)
NEWSAPI_API_KEY=

# GNews (https://gnews.io - 免费注册, 100次/天)
GNEWS_API_KEY=

# ---------- 默认 LLM 配置 ----------
# 可选: openai / anthropic / grok / ollama
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o
DEFAULT_LLM_API_KEY=

# ---------- LLM Provider Keys ----------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROK_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ---------- 应用设置 ----------
# 新闻拉取间隔(秒)
NEWS_POLL_INTERVAL=120
# 每批分析数量
ANALYSIS_BATCH_SIZE=5
# X情绪分析间隔(秒)
X_SENTIMENT_INTERVAL=1800
